{
  "permissions": {
    "auto_approve": [
      "read_file",
      "write_file",
      "edit_file",
      "search_files",
      "web_search",
      "web_fetch",
      "shell:git add*",
      "shell:git commit*",
      "shell:git push*",
      "shell:git status*",
      "shell:git diff*",
      "shell:git log*",
      "shell:ls *",
      "shell:mkdir *"
    ]
  },
  "hooks": {
    "pre_tool_use": {
      "command": "./hooks/pre-tool-guard.sh"
    },
    "post_tool_use": {
      "command": "./hooks/post-tool-guard.sh"
    },
    "user_prompt": {
      "command": "./hooks/prompt-guard.sh"
    }
  }
}
