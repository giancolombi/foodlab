{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "api/Dockerfile",
    "buildContext": "."
  },
  "deploy": {
    "startCommand": "pnpm run cron:hunt -- --mode=both",
    "cronSchedule": "0 12 * * *",
    "restartPolicyType": "NEVER"
  }
}
