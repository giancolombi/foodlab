{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "app/Dockerfile",
    "buildContext": "."
  },
  "deploy": {
    "startCommand": "/bin/sh -c \"export NGINX_RESOLVER=$(awk '/^nameserver/ {printf \\\"%s \\\", $2}' /etc/resolv.conf); envsubst '$API_UPSTREAM $NGINX_RESOLVER' < /etc/nginx/conf.d/default.conf > /tmp/default.conf && mv /tmp/default.conf /etc/nginx/conf.d/default.conf && nginx -g 'daemon off;'\"",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
