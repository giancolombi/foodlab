# API server
API_PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/foodlab
JWT_SECRET=change-me-to-a-long-random-string
RECIPES_DIR=../test-kitchen/recipes

# Ollama
OLLAMA_URL=http://localhost:11434
# Default is qwen3.6:27b (multilingual JSON, thinking-capable, ~17GB at q4).
# For lighter machines / smaller Railway plans, override to e.g. qwen3:8b
# or qwen2.5:3b. Set OLLAMA_THINKING=false when using a non-thinking model.
OLLAMA_MODEL=qwen3.6:27b
# OLLAMA_THINKING=false

# Optional per-function model routing — each falls back to OLLAMA_MODEL.
# Useful for keeping the matcher on a fast local model while routing
# modify/compose to a beefier (or even cloud, e.g. deepseek-v4-flash) model.
# OLLAMA_MODEL_MATCH=qwen3:8b
# OLLAMA_MODEL_MODIFY=deepseek-v4-flash
# OLLAMA_MODEL_COMPOSE=deepseek-v4-flash
# OLLAMA_MODEL_SHOPPING=qwen3.6:27b
# OLLAMA_MODEL_EXTRACT=qwen3.6:27b
# OLLAMA_MODEL_EXPAND=qwen3.6:27b

# Frontend build-time
VITE_API_URL=http://localhost:3001
