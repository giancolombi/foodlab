# API server
API_PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/foodlab
JWT_SECRET=change-me-to-a-long-random-string
RECIPES_DIR=../test-kitchen/recipes

# LLM — any OpenAI-compatible /chat/completions endpoint. Defaults to Google
# Gemini. Get a key at https://aistudio.google.com — set LLM_API_KEY in your
# environment (or Railway); NEVER commit it.
LLM_API_KEY=
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# gemini-3.1-flash-lite is the latest *stable* Flash-Lite — free-tier eligible
# and cheapest. Preview models enable billing, so avoid them for free tier.
LLM_MODEL=gemini-3.1-flash-lite

# Optional per-function model routing — each falls back to LLM_MODEL.
# e.g. keep the matcher cheap, route modify/compose to a stronger model.
# LLM_MODEL_MATCH=gemini-3.1-flash-lite
# LLM_MODEL_MODIFY=gemini-3-flash-preview
# LLM_MODEL_COMPOSE=gemini-3-flash-preview
# LLM_MODEL_SHOPPING=gemini-3.1-flash-lite
# LLM_MODEL_EXTRACT=gemini-3.1-flash-lite
# LLM_MODEL_EXPAND=gemini-3.1-flash-lite
#
# To run against a local Ollama instead, point at its OpenAI-compatible API:
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=qwen3.5:4b

# Frontend build-time
VITE_API_URL=http://localhost:3001
